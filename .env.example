# KIS credentials
KIS_APP_KEY=
KIS_APP_SECRET=
# 1: paper, 0: real
KIS_PAPER=0
# Optional override. If empty, URL is derived from KIS_PAPER.
KIS_BASE_URL=

# Optional legacy/bootstrap account. Runtime alias accounts are read from MySQL trade_accounts.
KIS_ACCOUNT_NO=
KIS_ACNT_PRDT=01
# Alternative single-field format
KIS_ACCOUNT_FULL=

# Optional bootstrap aliases. Prefer bind-account so runtime reads these from MySQL.
SYSTEM_TRADE_ACCOUNT_TEST=
SYSTEM_TRADE_ACCOUNT_HAGFISH=
SYSTEM_TRADE_ACCOUNT_HALFRISE=
# Optional per-account KIS app credentials. Use when KIS keys are account-specific.
SYSTEM_TRADE_APP_KEY_TEST=
SYSTEM_TRADE_APP_SECRET_TEST=
SYSTEM_TRADE_APP_KEY_HAGFISH=
SYSTEM_TRADE_APP_SECRET_HAGFISH=
SYSTEM_TRADE_APP_KEY_HALFRISE=
SYSTEM_TRADE_APP_SECRET_HALFRISE=
# Optional default alias. Usually prefer passing --account-alias per command.
SYSTEM_TRADE_ACCOUNT_ALIAS=

# MySQL for execution ledger
SYSTEM_TRADE_DB_HOST=127.0.0.1
SYSTEM_TRADE_DB_PORT=3306
SYSTEM_TRADE_DB_USER=root
SYSTEM_TRADE_DB_PASSWORD=
SYSTEM_TRADE_DB_NAME=trade
